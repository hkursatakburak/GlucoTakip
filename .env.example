# Google OAuth2 Credentials
# Get these from Google Cloud Console (APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Apple OAuth2 Credentials
# Get these from Apple Developer Portal
APPLE_CLIENT_ID=your_apple_client_id_here
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_apple_private_key_string\n-----END PRIVATE KEY-----"

# Application Secrets
# Used for signing JWT tokens and Authlib sessions
SECRET_KEY=supersecretkey_please_change_in_production

# SMTP Server Settings (for Email Verification and Forgot Password)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=your_email@gmail.com
